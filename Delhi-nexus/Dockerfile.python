# Use Python 3.11
FROM python:3.11-slim

WORKDIR /app

# Install dependencies directly since requirements.txt creation is restricted
RUN pip install --no-cache-dir fastapi uvicorn pandas numpy scikit-learn statsmodels pydantic

# Copy source code
COPY server/ai_service.py ./server/

# Expose port
EXPOSE 5001

# Start server
CMD ["uvicorn", "server.ai_service:app", "--host", "0.0.0.0", "--port", "5001"]
